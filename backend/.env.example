# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ecycle

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Admin default credentials (change after first login)
ADMIN_EMAIL=admin@ecycle.com
ADMIN_PASSWORD=Admin@123456

# Secret codeword required when scanning QR at recycling center
# Change this to something only your staff knows!
VERIFY_CODEWORD=ecycle123
